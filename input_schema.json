{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "task": {"type": "string"},
    "phase": {"type": "string", "pattern": "[1-7]"},
    "gaps": {"type": "array", "items": {"type": "string"}},
    "glyphs": {"type": "array", "items": {"type": "string", "pattern": "[φψω]-\\d+"}},
    "threats": {"type": "array", "items": {"type": "object", "properties": {"name": {"type": "string"}, "weight": {"type": "number"}}}}
  },
  "required": ["task", "phase"]
}